includes:
    - vendor/szepeviktor/phpstan-wordpress/extension.neon

parameters:
    level: 5
    paths:
        - wp-content/plugins/trello-social-auto-publisher
    tmpDir: .phpstan-cache
    treatPhpDocTypesAsCertain: false
    inferPrivatePropertyTypeFromConstructor: true
    scanDirectories:
        - vendor/php-stubs/wordpress-stubs
    bootstrapFiles:
        - wp-content/plugins/trello-social-auto-publisher/tests/bootstrap.php
    excludePaths:
        - */vendor/*
        - */node_modules/*
        - */tests/fixtures/*
